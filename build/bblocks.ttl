<bblocks://ogc.api.processes.part1.requirements.core> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Requirements-class ;
    rdfs:label "Core" ;
    dct:abstract "Core requirements class for OGC API — Processes Part 1. Specifies the fundamental operations a server must support: landing page, conformance declaration, process list, process description, process execution, job status, and job results."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
